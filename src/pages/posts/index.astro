---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllPosts, getAllTags } from "../../lib/posts";

const allPosts = await getAllPosts();
const allTags = await getAllTags();
const years = [...new Set(allPosts.map((p) => String(new Date(p.date).getFullYear())))].sort((a, b) => Number(b) - Number(a));
---

<BaseLayout title="記事一覧 | 砕けた水槽クラブ">
  <main class="wrapper posts-page">
    <h1 class="midashi">記事一覧</h1>

    <section class="filter-section">
      <div class="tag-filter">
        <button class="tag-btn active" data-tag="">すべて</button>
        {allTags.map((t) => (
          <button class="tag-btn" data-tag={t}>{t}</button>
        ))}
      </div>
      <div class="date-filter">
        <select id="year-select">
          <option value="">年を選択</option>
          {years.map((y) => (
            <option value={y}>{y}年</option>
          ))}
        </select>
        <select id="month-select">
          <option value="">月を選択</option>
          {Array.from({ length: 12 }, (_, i) => i + 1).map((m) => (
            <option value={String(m).padStart(2, "0")}>{m}月</option>
          ))}
        </select>
      </div>
    </section>

    <p class="post-count" id="post-count">{allPosts.length}件の記事</p>

    <div class="card-grid" id="card-grid">
      {allPosts.map((post) => (
        <a href={"/posts/" + post.id + "/"} class="card" data-tags={JSON.stringify(post.tags ?? [])} data-year={String(new Date(post.date).getFullYear())} data-month={String(new Date(post.date).getMonth() + 1).padStart(2, "0")}>
          <div class="card-img">
            {post.image ? (
              <img src={post.image.url} alt={post.title} loading="lazy" />
            ) : (
              <div class="card-img-placeholder">📝</div>
            )}
          </div>
          <div class="card-body">
            <h2 class="card-title">{post.title}</h2>
            <p class="card-date">{new Date(post.date).toLocaleDateString("ja-JP", { year: "numeric", month: "long", day: "numeric" })}</p>
            {post.description && <p class="card-desc">{post.description}</p>}
            {(post.tags ?? []).length > 0 && (
              <ul class="card-tags">
                {post.tags.map((t) => <li>{t}</li>)}
              </ul>
            )}
          </div>
        </a>
      ))}
    </div>

    <p class="no-posts" id="no-posts" style="display:none;">該当する記事がありません。</p>

    <nav class="pagination" id="pagination"></nav>
  </main>
</BaseLayout>

<script>
const POSTS_PER_PAGE = 10;
let currentTag = "";
let currentYear = "";
let currentMonth = "";
let currentPage = 1;

const cards = Array.from(document.querySelectorAll("#card-grid .card"));
const noPosts = document.getElementById("no-posts");
const postCount = document.getElementById("post-count");
const pagination = document.getElementById("pagination");

function getFiltered() {
  return cards.filter((card) => {
    const tags = JSON.parse(card.dataset.tags ?? "[]");
    const year = card.dataset.year ?? "";
    const month = card.dataset.month ?? "";
    if (currentTag && !tags.includes(currentTag)) return false;
    if (currentYear && year !== currentYear) return false;
    if (currentMonth && month !== currentMonth) return false;
    return true;
  });
}

function render() {
  const filtered = getFiltered();
  const total = filtered.length;
  const totalPages = Math.max(1, Math.ceil(total / POSTS_PER_PAGE));
  currentPage = Math.min(currentPage, totalPages);
  const start = (currentPage - 1) * POSTS_PER_PAGE;
  const visible = filtered.slice(start, start + POSTS_PER_PAGE);

  cards.forEach((card) => (card.style.display = "none"));
  visible.forEach((card) => (card.style.display = "flex"));

  postCount.textContent = total + "件の記事";
  noPosts.style.display = total === 0 ? "block" : "none";

  pagination.innerHTML = "";
  if (totalPages > 1) {
    if (currentPage > 1) {
      const btn = document.createElement("button");
      btn.className = "page-btn";
      btn.textContent = "← 前へ";
      btn.onclick = () => { currentPage--; render(); };
      pagination.appendChild(btn);
    }
    for (let i = 1; i <= totalPages; i++) {
      const btn = document.createElement("button");
      btn.className = "page-btn" + (i === currentPage ? " current" : "");
      btn.textContent = String(i);
      btn.onclick = () => { currentPage = i; render(); };
      pagination.appendChild(btn);
    }
    if (currentPage < totalPages) {
      const btn = document.createElement("button");
      btn.className = "page-btn";
      btn.textContent = "次へ →";
      btn.onclick = () => { currentPage++; render(); };
      pagination.appendChild(btn);
    }
  }
}

document.querySelectorAll(".tag-btn").forEach((btn) => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".tag-btn").forEach((b) => b.classList.remove("active"));
    btn.classList.add("active");
    currentTag = btn.dataset.tag ?? "";
    currentPage = 1;
    render();
  });
});

document.getElementById("year-select").addEventListener("change", (e) => {
  currentYear = e.target.value;
  currentPage = 1;
  render();
});

document.getElementById("month-select").addEventListener("change", (e) => {
  currentMonth = e.target.value;
  currentPage = 1;
  render();
});

render();
</script>
